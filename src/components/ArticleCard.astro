---
export interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  publishedAt: Date;
}

const { title, description, tags, slug, publishedAt } = Astro.props;
const dateStr = publishedAt.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
});
---

<article style={{
  minHeight: "300px",
  padding: "26px",
  display: "flex",
  flexDirection: "column",
  justifyContent: "space-between",
  borderRight: "1px solid #bbb",
  background: "#fff",
}}>
  <a href={`/writing/${slug}/`} style={{textDecoration: "none", color: "inherit", display: "flex", flexDirection: "column", height: "100%"}}>
    <div>
      <div style={{font: "700 12px/1.4 ui-monospace,monospace", color: "#666", marginBottom: "12px"}}>
        {tags[0]} &middot; 8 MIN
      </div>
      <h3 style={{fontFamily: "Georgia,'Songti SC',serif", fontSize: "clamp(22px,2.5vw,30px)", lineHeight: 1.2, fontWeight: 700, margin: "0 0 10px"}}>{title}</h3>
      <p style={{fontSize: "15px", lineHeight: 1.6, color: "#666", margin: 0}}>{description}</p>
    </div>
    <div style={{font: "700 12px/1.4 ui-monospace,monospace", color: "#666", marginTop: "auto"}}>{dateStr} &rarr;</div>
  </a>
</article>
