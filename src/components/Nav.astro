---
const links = [
  { href: "/projects/", label: "Work" },
  { href: "/writing/", label: "Writing" },
  { href: "/about/", label: "About" },
];
---

<nav style="border-bottom:2px solid var(--color-border-strong); background:rgba(244,241,232,.96); position:sticky;top:0;z-index:10">
  <div style="max-width:1440px;margin:0 auto;height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 28px;border-left:var(--border-thick);border-right:var(--border-thick)">
    <a href="/" style="font:700 13px/1 ui-monospace,monospace;letter-spacing:.04em;text-decoration:none;text-transform:uppercase;color:var(--color-text-primary)">KAKARROT.COM</a>
    <ul style="display:flex;gap:28px;list-style:none;margin:0;padding:0">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            style="font:700 13px/1 ui-monospace,monospace;letter-spacing:.04em;text-decoration:none;text-transform:uppercase;color:var(--color-text-secondary)"
            onmouseover="this.style.color='var(--color-accent)'"
            onmouseout="this.style.color='var(--color-text-secondary)'"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <span style="font:700 13px/1 ui-monospace,monospace;color:var(--color-text-muted)">CN / 2026</span>
  </div>
</nav>
