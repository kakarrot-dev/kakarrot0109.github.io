---
const socialLinks = [
  { label: "TWITTER", url: "https://x.com/Kakarrot_me" },
  { label: "GITHUB", url: "https://github.com/kakarrot-dev" },
  { label: "TELEGRAM", url: "https://t.me/kakarrot_me" },
  { label: "E-MAIL", url: "mailto:i@kakarrot.com" },
];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell site-footer-inner">
    <strong class="site-footer-tagline">从零思考，<br />为现实构建。</strong>
    <div class="footer-bottom">
      <p class="site-footer-copy">
        &copy; 2016-{year} Kakarrot Design, All Rights Reserved
      </p>
      <nav class="site-footer-social">
        {
          socialLinks.map(({ label, url }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="social-link"
            >
              {label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text-primary);
    color: var(--color-bg-warm);
    padding: 64px 0;
  }
  .site-footer-inner {
    padding: 0 28px;
    border: none;
  }
  .site-footer-tagline {
    display: block;
    font-size: clamp(36px, 4vw, 54px);
    letter-spacing: -0.05em;
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 40px;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 20px;
  }
  .site-footer-copy {
    font: 700 13px/1.5 var(--font-mono);
    opacity: 0.6;
    margin: 0;
    flex-shrink: 0;
  }
  .site-footer-social {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  @media (max-width: 640px) {
    .footer-bottom {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
    }
  }
</style>
