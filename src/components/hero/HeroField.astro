---
import { socialLinks } from "@/data/social";
import SocialIcon from "@/components/SocialIcon.astro";
---

<section class="hero" data-hero>
  <div class="hero__fallback" data-hero-fallback aria-hidden="true"></div>
  <canvas class="hero__canvas" data-hero-canvas hidden></canvas>
  <div class="hero__content">
    <p class="hero__eyebrow">Personal Studio · AI PM</p>
    <h1 class="hero__brand">Kakarrot</h1>
    <p class="hero__tagline">
      从第一性原理出发，用 AI 原生方式做成可落地的产品与工具。
    </p>
    <div class="social-pills">
      {
        socialLinks.map(({ id, label, href, external }) => (
          <a
            class="social-pill"
            href={href}
            {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            <SocialIcon id={id} />
            <span>{label}</span>
          </a>
        ))
      }
    </div>
    <p class="hero__meta">Est. Zhengzhou</p>
  </div>
</section>

<script>
  const root = document.querySelector("[data-hero]");
  const canvas = document.querySelector<HTMLCanvasElement>("[data-hero-canvas]");
  const fallback = document.querySelector("[data-hero-fallback]");
  if (!root || !canvas) {
    /* no-op */
  } else {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      /* keep fallback */
    } else {
      void (async () => {
        try {
          const THREE = await import("three");
          const theme = () =>
            document.documentElement.getAttribute("data-theme") === "dark"
              ? { canvas: 0x2d2e2d, primary: 0xe6bf7a, ink: 0xe9e6dc }
              : { canvas: 0xf5f3e9, primary: 0xb7791f, ink: 0x29271d };

          canvas.hidden = false;
          if (fallback) fallback.setAttribute("hidden", "");

          const renderer = new THREE.WebGLRenderer({
            canvas,
            antialias: true,
            alpha: true,
          });
          renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

          const scene = new THREE.Scene();
          const camera = new THREE.PerspectiveCamera(42, 1, 0.1, 100);
          camera.position.z = 6;

          const colors = theme();
          scene.background = new THREE.Color(colors.canvas);

          // sparse points
          const count = 180;
          const positions = new Float32Array(count * 3);
          for (let i = 0; i < count; i++) {
            positions[i * 3] = (Math.random() - 0.5) * 14;
            positions[i * 3 + 1] = (Math.random() - 0.5) * 8;
            positions[i * 3 + 2] = (Math.random() - 0.5) * 4;
          }
          const geo = new THREE.BufferGeometry();
          geo.setAttribute("position", new THREE.BufferAttribute(positions, 3));
          const mat = new THREE.PointsMaterial({
            color: colors.primary,
            size: 0.035,
            transparent: true,
            opacity: 0.7,
            depthWrite: false,
          });
          const points = new THREE.Points(geo, mat);
          scene.add(points);

          // faint grid
          const grid = new THREE.GridHelper(16, 24, colors.primary, colors.primary);
          grid.rotation.x = Math.PI / 2;
          grid.position.z = -2;
          const gridMats = Array.isArray(grid.material) ? grid.material : [grid.material];
          gridMats.forEach((m) => {
            m.transparent = true;
            m.opacity = 0.12;
          });
          scene.add(grid);

          let w = 0;
          let h = 0;
          const pointer = { x: 0, y: 0 };
          const target = { x: 0, y: 0 };

          const resize = () => {
            const rect = root.getBoundingClientRect();
            w = rect.width;
            h = rect.height;
            renderer.setSize(w, h, false);
            camera.aspect = w / Math.max(h, 1);
            camera.updateProjectionMatrix();
          };
          resize();
          window.addEventListener("resize", resize);

          root.addEventListener("pointermove", (e) => {
            const ev = e as PointerEvent;
            const rect = root.getBoundingClientRect();
            target.x = ((ev.clientX - rect.left) / rect.width - 0.5) * 2;
            target.y = ((ev.clientY - rect.top) / rect.height - 0.5) * 2;
          });

          const syncTheme = () => {
            const c = theme();
            scene.background = new THREE.Color(c.canvas);
            mat.color.setHex(c.primary);
            gridMats.forEach((m) => {
              if ("color" in m && m.color) (m.color as InstanceType<typeof THREE.Color>).setHex(c.primary);
            });
          };
          const mo = new MutationObserver(syncTheme);
          mo.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ["data-theme"],
          });

          let raf = 0;
          const tick = (t: number) => {
            pointer.x += (target.x - pointer.x) * 0.04;
            pointer.y += (target.y - pointer.y) * 0.04;
            points.rotation.y = t * 0.00005 + pointer.x * 0.12;
            points.rotation.x = pointer.y * 0.08;
            grid.position.x = pointer.x * 0.3;
            grid.position.y = -pointer.y * 0.2;
            renderer.render(scene, camera);
            raf = requestAnimationFrame(tick);
          };
          raf = requestAnimationFrame(tick);

          document.addEventListener("visibilitychange", () => {
            if (document.hidden) cancelAnimationFrame(raf);
            else raf = requestAnimationFrame(tick);
          });
        } catch {
          canvas.hidden = true;
          fallback?.removeAttribute("hidden");
        }
      })();
    }
  }
</script>
