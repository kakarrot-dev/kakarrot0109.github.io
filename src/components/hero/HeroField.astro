---
import { socialLinks } from "@/data/social";
import SocialIcon from "@/components/SocialIcon.astro";
---

<section class="hero" data-hero>
  <div class="hero__fallback" data-hero-fallback aria-hidden="true"></div>
  <canvas class="hero__canvas" data-hero-canvas hidden></canvas>
  <div class="hero__content">
    <p class="hero__eyebrow">Personal Studio · AI PM</p>
    <h1 class="hero__brand">Kakarrot</h1>
    <p class="hero__tagline">
      从第一性原理出发，用 AI 原生方式做成可落地的产品与工具。
    </p>
    <div class="social-pills">
      {
        socialLinks.map(({ id, label, href, external }) => (
          <a
            class="social-pill"
            href={href}
            {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            <SocialIcon id={id} />
            <span>{label}</span>
          </a>
        ))
      }
    </div>
    <p class="hero__meta">Est. Zhengzhou</p>
  </div>
</section>

<script>
  const root = document.querySelector("[data-hero]");
  const canvas = document.querySelector<HTMLCanvasElement>("[data-hero-canvas]");
  const fallback = document.querySelector("[data-hero-fallback]");
  if (!root || !canvas) {
    /* no-op */
  } else {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      /* keep fallback */
    } else {
      const context = canvas.getContext("2d");
      if (!context) {
        canvas.hidden = true;
        fallback?.removeAttribute("hidden");
      } else {
        const theme = () =>
          document.documentElement.getAttribute("data-theme") === "dark"
            ? { canvas: "#2d2e2d", primary: "#e6bf7a" }
            : { canvas: "#f5f3e9", primary: "#b7791f" };
        const points = Array.from({ length: 180 }, () => ({
          x: Math.random(),
          y: Math.random(),
          depth: 0.35 + Math.random() * 0.65,
          size: 0.6 + Math.random() * 1.4,
        }));
        const pointer = { x: 0, y: 0 };
        const target = { x: 0, y: 0 };
        let width = 0;
        let height = 0;
        let dpr = 1;
        let raf = 0;

        canvas.hidden = false;
        fallback?.setAttribute("hidden", "");

        const resize = () => {
          const rect = root.getBoundingClientRect();
          width = rect.width;
          height = rect.height;
          dpr = Math.min(window.devicePixelRatio, 2);
          canvas.width = Math.round(width * dpr);
          canvas.height = Math.round(height * dpr);
          canvas.style.width = `${width}px`;
          canvas.style.height = `${height}px`;
          context.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        const draw = (time: number) => {
          // 指针跟随：桌面/触控共用，略加快以免「拖泥」
          pointer.x += (target.x - pointer.x) * 0.08;
          pointer.y += (target.y - pointer.y) * 0.08;
          const colors = theme();
          context.fillStyle = colors.canvas;
          context.fillRect(0, 0, width, height);

          const gridSize = Math.max(56, width / 24);
          const gridOffsetX = (pointer.x * 24) % gridSize;
          const gridOffsetY = (-pointer.y * 16) % gridSize;
          context.strokeStyle = `${colors.primary}1f`;
          context.lineWidth = 1;
          context.beginPath();
          for (let x = gridOffsetX; x <= width; x += gridSize) {
            context.moveTo(x, 0);
            context.lineTo(x, height);
          }
          for (let y = gridOffsetY; y <= height; y += gridSize) {
            context.moveTo(0, y);
            context.lineTo(width, y);
          }
          context.stroke();

          context.fillStyle = `${colors.primary}b3`;
          for (const point of points) {
            // 粒子漂移：约 4× 原速，桌面与 iOS 同一套
            const drift = time * 0.000024 * point.depth;
            const x =
              ((point.x + drift) % 1) * width +
              pointer.x * 28 * point.depth;
            const y = point.y * height - pointer.y * 18 * point.depth;
            context.globalAlpha = 0.35 + point.depth * 0.4;
            context.fillRect(x, y, point.size, point.size);
          }
          context.globalAlpha = 1;
          raf = requestAnimationFrame(draw);
        };

        resize();
        window.addEventListener("resize", resize);
        root.addEventListener("pointermove", (event) => {
          const pointerEvent = event as PointerEvent;
          const rect = root.getBoundingClientRect();
          target.x = ((pointerEvent.clientX - rect.left) / rect.width - 0.5) * 2;
          target.y = ((pointerEvent.clientY - rect.top) / rect.height - 0.5) * 2;
        });
        raf = requestAnimationFrame(draw);

        document.addEventListener("visibilitychange", () => {
          if (document.hidden) cancelAnimationFrame(raf);
          else raf = requestAnimationFrame(draw);
        });
      }
    }
  }
</script>
