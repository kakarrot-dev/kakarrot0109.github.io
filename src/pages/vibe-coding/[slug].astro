---
import ProseLayout from "@/layouts/ProseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("vibe-coding");
  return items
    .filter((p) => !p.data.draft)
    .map((p) => ({
      params: { slug: p.id },
      props: { item: p },
    }));
}

const { item } = Astro.props;
const { Content, headings } = await render(item);
const canonical = `/vibe-coding/${item.id}/`;
---

<ProseLayout
  title={item.data.title}
  description={item.data.description}
  canonical={canonical}
  publishedAt={item.data.publishedAt}
  tags={item.data.topics}
  headings={headings}
>
  <Content />
  <p style="margin-top:2.5rem">
    <a href="/vibe-coding/" class="section-link">← Vibe Coding</a>
  </p>
</ProseLayout>
