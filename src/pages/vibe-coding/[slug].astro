---
import ProseLayout from "@/layouts/ProseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("vibe-coding");
  return items
    .filter((p) => !p.data.draft)
    .map((p) => ({
      params: { slug: p.id },
      props: { item: p },
    }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const canonical = `/vibe-coding/${item.id}/`;
---

<ProseLayout
  title={item.data.title}
  description={item.data.description}
  canonical={canonical}
  publishedAt={item.data.publishedAt}
  tags={item.data.topics}
>
  <p class="text-xs text-[var(--color-text-muted)] font-mono">
    发布时间：{item.data.publishedAt.toLocaleDateString("zh-CN")}
  </p>
  <Content />
</ProseLayout>
