---
import ProseLayout from "@/layouts/ProseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("vibe-coding");
  return items
    .filter((p) => !p.data.draft)
    .map((p) => ({
      params: { slug: p.slug },
      props: { item: p },
    }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<ProseLayout title={item.data.title} description={item.data.description}>
  <p class="text-xs text-[var(--color-text-muted)] font-mono">
    发布时间：{item.data.publishedAt.toLocaleDateString("zh-CN")}
  </p>
  <Content />
</ProseLayout>
