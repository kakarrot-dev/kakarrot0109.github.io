---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WorkCard from "@/components/WorkCard.astro";
import { getCollection } from "astro:content";

const orderedSlugs = [
  "wukong",
  "kakarrot-website",
  "claude-cream",
  "obsidian-wiki",
  "pm-ai-agent-book",
  "tampermonkey",
] as const;

const publishedItems = (await getCollection("vibe-coding")).filter(
  (item) => !item.data.draft
);
const itemsBySlug = new Map(publishedItems.map((item) => [item.id, item]));
const ordered = orderedSlugs
  .map((slug) => itemsBySlug.get(slug))
  .filter((item): item is (typeof publishedItems)[number] => !!item);
const rest = publishedItems.filter((item) => !orderedSlugs.includes(item.id as (typeof orderedSlugs)[number]));
const items = [...ordered, ...rest];

const topics = [...new Set(items.flatMap((i) => i.data.topics))];

function formatMeta(date: Date, t?: string[]) {
  const d = date.toLocaleDateString("en-CA").replace(/-/g, ".");
  return t?.[0] ? `${d} · ${t[0]}` : d;
}
---

<BaseLayout
  title="Vibe Coding"
  description="AI 协作构建的产品与实验"
  canonical="/vibe-coding/"
>
  <div class="container section page-shell">
    <header class="page-header">
      <p class="page-eyebrow">Vibe Coding</p>
      <h1 class="page-title">Selected Works</h1>
      <p class="page-lead">用 AI 原生方式做出来的工具、站点与实验</p>
      <div class="stat-bar">
        <span><strong>{items.length}</strong> works</span>
        <span><strong>{topics.length}</strong> topics</span>
      </div>
    </header>

    <div class="work-grid">
      {
        items.map((p, i) => (
          <div class={`reveal reveal-delay-${(i % 3) + 1}`}>
            <WorkCard
              title={p.data.title}
              description={p.data.description}
              href={`/vibe-coding/${p.id}/`}
              cover={p.data.cover}
              meta={formatMeta(p.data.publishedAt, p.data.topics)}
            />
          </div>
        ))
      }
    </div>
  </div>
</BaseLayout>
