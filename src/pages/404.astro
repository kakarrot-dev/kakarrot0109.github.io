---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404" description="页面不存在" shell>
  <div style={{padding: "120px 30px", textAlign: "center", borderBottom: "2px solid var(--color-border-strong)"}}>
    <h1 style={{fontSize: "clamp(80px,15vw,160px)", letterSpacing: "-.07em", lineHeight: .9, fontWeight: 900, margin: "0 0 16px"}}>404</h1>
    <p style={{fontSize: "24px", color: "var(--color-text-secondary)", margin: "0 0 32px"}}>页面不存在</p>
    <a href="/" style={{font: "700 14px/1 var(--font-mono)", textTransform: "uppercase", letterSpacing: ".04em", textUnderlineOffset: "3px"}}>返回首页</a>
  </div>
</BaseLayout>
