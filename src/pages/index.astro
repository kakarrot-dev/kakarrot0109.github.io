---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroField from "@/components/hero/HeroField.astro";
import WorkCard from "@/components/WorkCard.astro";
import ArticleRow from "@/components/ArticleRow.astro";
import { getCollection } from "astro:content";

const vibeFeatured = (await getCollection("vibe-coding"))
  .filter((p) => !p.data.draft && p.data.featured)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 6);

const vibeForMarquee = [...vibeFeatured, ...vibeFeatured];

const writingFeatured = (await getCollection("writing"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 5);

function formatMeta(date: Date, topics?: string[]) {
  const d = date.toLocaleDateString("en-CA").replace(/-/g, ".");
  const t = topics?.[0];
  return t ? `${d} · ${t}` : d;
}
---

<BaseLayout
  title="Kakarrot"
  description="AI 产品经理 — 从第一性原理拆解复杂业务，用 AI 原生方式做成可落地的产品系统。"
  canonical="/"
>
  <HeroField />

  <section class="section reveal">
    <div class="container section-head">
      <div class="section-head__left">
        <span class="section-num">01</span>
        <h2 class="section-title">Vibe Coding</h2>
        <p class="section-desc">用 AI 原生方式做出来的工具、站点与实验</p>
      </div>
      <a class="section-link" href="/vibe-coding/">View all →</a>
    </div>
    <div class="marquee" aria-label="精选作品横向展示">
      <div class="marquee__track">
        {
          vibeForMarquee.map((p) => (
            <div class="marquee__item">
              <WorkCard
                title={p.data.title}
                description={p.data.description}
                href={`/vibe-coding/${p.id}/`}
                cover={p.data.cover}
                meta={formatMeta(p.data.publishedAt, p.data.topics)}
              />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section reveal" style="padding-top:0">
    <div class="container">
      <div class="section-head">
        <div class="section-head__left">
          <span class="section-num">02</span>
          <h2 class="section-title">Writing</h2>
          <p class="section-desc">关于 AI 产品、方法论与实践的思考</p>
        </div>
        <a class="section-link" href="/writing/">View all →</a>
      </div>
      <div>
        {
          writingFeatured.map((a) => (
            <ArticleRow
              title={a.data.title}
              description={a.data.description}
              href={`/writing/${a.id}/`}
              date={a.data.publishedAt}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section reveal" style="padding-top:0;padding-bottom:96px">
    <div class="container">
      <div class="about-note">
        <div class="about-note__rail" aria-hidden="true"></div>
        <div>
          <p class="about-note__label">Note</p>
          <p>
            10 年+ 产品经理，坐标郑州。热衷把业务问题拆回第一性原理，再用 AI 原生方式重做产品与工作流。
          </p>
          <p>
            这里记录 vibe coding 实验与方法论沉淀。
            <a href="/about/">About →</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
