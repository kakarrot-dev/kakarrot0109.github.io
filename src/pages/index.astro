---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("vibe-coding"))
  .filter((p) => !p.data.draft);

const featuredArticles = (await getCollection("writing"))
  .filter((p) => !p.data.draft && p.data.featured)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title="Kakarrot" description="AI 产品经理 — 从第一性原理拆解复杂业务，用 AI 原生方式做成可落地的产品系统。" canonical="/">
  <!-- Hero — 单栏大留白，头像靠右 -->
  <div class="full-bleed" style="border-bottom:2px solid var(--color-border-strong);background:var(--color-bg-warm)">
    <div style="max-width:1536px;margin:0 auto;padding:clamp(80px,10vw,140px) clamp(32px,6vw,80px) clamp(64px,8vw,120px)">
      <!-- 第一行：名字 + 头像（居中） -->
      <div class="hero-row" style="display:flex;align-items:center;justify-content:center;gap:clamp(16px,2.5vw,40px)">
        <h1 style="font-size:var(--text-hero);line-height:var(--lh-hero);letter-spacing:var(--ls-hero);font-weight:900;text-transform:uppercase;margin:0;color:var(--color-text-primary)">
          <span class="hero-line"><span>KAKARROT</span></span>
        </h1>
        <picture>
          <source srcset="/avatar.webp" type="image/webp" />
          <img
            src="/avatar.jpeg"
            alt="Kakarrot"
            class="avatar-img"
            width="160"
            height="160"
            fetchpriority="high"
          />
        </picture>
      </div>
      <!-- 间距 -->
      <div style="margin-top:clamp(48px,7vw,120px)"></div>
      <!-- 介绍文案 -->
      <div style="padding-left:clamp(16px,2vw,24px);border-left:4px solid var(--color-accent)">
        <p class="hero-fade" style="font:400 16px/1.6 var(--font-mono);margin:0;color:var(--color-text-secondary)">
          大家好！我是 Kakarrot，一名拥有 <span class="highlight-ai">10 年+经验产品经理</span>。我的职业履历涵盖拓普丰联、宇通集团、南威集团等中国行业知名企业，熟悉互联网及项目产品从 0-1 创业流程，同时熟悉二开产品从 1-∞ 迭代流程。
        </p>
        <p class="hero-fade" style="font:400 16px/1.6 var(--font-mono);margin:16px 0 0;color:var(--color-text-secondary)">
          我热衷于探索产品、商业、人工智能的融合领域。我擅长 <span class="highlight-ai">从第一性原理出发，识别业务真正的问题，用 AI 原生方式重新设计产品与增长系统。</span>
        </p>
        <p class="hero-fade" style="font:400 16px/1.6 var(--font-mono);margin:16px 0 0;color:var(--color-text-secondary)">
          当前的 AI 对整个行业及相关产业链冲击巨大，我也在学习和整理全新的工作流程——通过结合 <span class="highlight-ai">AI 技术与直觉洞察</span>，加速产品开发进程并激发创造性协作。
        </p>
      </div>
    </div>
  </div>

  <!-- 跑马条 -->
  <div class="full-bleed" style={{overflow: "hidden", background: "var(--color-accent)", borderBottom: "2px solid var(--color-border-strong)", color: "#000"}}>
    <div style={{fontSize: "clamp(36px,4vw,52px)", fontWeight: 900, letterSpacing: "-.04em", whiteSpace: "nowrap", overflow: "hidden"}}>
      <div class="marquee-track" style={{gap: 0}}>
        <span style={{padding: "14px 0"}}>PROJECTS &middot; BUSINESS SYSTEMS &middot; AI NATIVE &middot; FIRST PRINCIPLES &middot; </span>
        <span style={{padding: "14px 0"}}>PROJECTS &middot; BUSINESS SYSTEMS &middot; AI NATIVE &middot; FIRST PRINCIPLES &middot; </span>
        <span style={{padding: "14px 0"}}>PROJECTS &middot; BUSINESS SYSTEMS &middot; AI NATIVE &middot; FIRST PRINCIPLES &middot; </span>
      </div>
    </div>
  </div>

  <!-- 方法论 -->
  <div class="full-bleed reveal" style="border-bottom:2px solid var(--color-border-strong)">
    <div class="grid-split" style="display:grid;grid-template-columns:.55fr 1.45fr">
      <div style={{padding: "38px 30px", borderRight: "2px solid var(--color-border-strong)"}}>
        <div style={{font: "700 13px/1.5 var(--font-mono)", color: "var(--color-text-muted)", marginBottom: "14px"}}>METHOD / 方法论</div>
        <h2 style={{fontSize: "var(--text-method-title)", lineHeight: "var(--lh-method-title)", letterSpacing: "var(--ls-method-title)", fontWeight: 900, margin: "120px 0 14px"}}>不是给旧流程<br />加一个 AI。</h2>
        <p style={{font: "14px/1.6 var(--font-mono)", color: "var(--color-text-secondary)", marginTop: "14px"}}>从问题和约束重新推导产品，而不是从功能列表出发。</p>
      </div>
      <div class="grid-3" style={{display: "grid", gridTemplateColumns: "repeat(3, 1fr)"}}>
        {[{step:"01",title:"找到本质问题",desc:"去掉行业惯例和历史包袱，确认用户真正要完成的任务。"},{step:"02",title:"拆解业务系统",desc:"把用户、价值、流程、成本与增长放回同一张地图。"},{step:"03",title:"AI 原生重构",desc:"重新分配人与机器的职责，设计新的产品形态与反馈闭环。"}].map(({step,title,desc},i)=>(
          <article key={step} class={"reveal reveal-delay-" + (i+1)} style={{minHeight: "400px", padding: "34px 28px", display: "flex", flexDirection: "column", justifyContent: "space-between", borderRight: i < 2 ? "2px solid var(--color-border-strong)" : "none", background: i === 1 ? "var(--color-accent)" : "transparent"}}>
            <span style={{font: "700 16px/1 var(--font-mono)", color: i === 1 ? "var(--color-text-primary)" : "var(--color-text-muted)"}}>{step}</span>
            <div>
              <h3 style={{fontSize: "clamp(28px,2.5vw,36px)", lineHeight: 1.05, margin: "0 0 16px", fontWeight: 700}}>{title}</h3>
              <p style={{fontSize: "17px", lineHeight: 1.6, margin: 0, color: i === 1 ? "var(--color-text-primary)" : "var(--color-text-secondary)"}}>{desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Vibe Coding 精选 -->
  <div class="shell reveal" style="border-top:0;border-bottom:2px solid var(--color-border-strong)">
    <div style={{padding: "38px 30px", display: "flex", justifyContent: "space-between", alignItems: "end", borderBottom: "2px solid var(--color-border-strong)"}}>
      <h2 style={{fontSize: "var(--text-section-title)", letterSpacing: "var(--ls-section-title)", lineHeight: "var(--lh-section-title)", fontWeight: 900, margin: 0}}>VIBE CODING</h2>
      <span style={{font: "700 13px/1.5 var(--font-mono)", color: "var(--color-text-muted)"}}>SELECTED WORK / 02</span>
    </div>
    <div class="grid-2" style={{display: "grid", gridTemplateColumns: "1fr 1fr", gap: "24px", padding: "24px"}}>
      {featuredProjects.map((p, i) => (
        <div key={p.slug} class={"reveal reveal-delay-" + (i+1)}>
          <ProjectCard title={p.data.title} description={p.data.description} topics={p.data.topics} href={`/vibe-coding/${p.slug}/`} />
        </div>
      ))}
    </div>
  </div>

  <!-- 文章区 -->
  <div class="shell reveal" style="border-top:0">
    <div style={{padding: "38px 30px", display: "flex", justifyContent: "space-between", alignItems: "end", borderBottom: "2px solid var(--color-border-strong)"}}>
      <h2 style={{fontSize: "var(--text-section-title)", letterSpacing: "var(--ls-section-title)", lineHeight: "var(--lh-section-title)", fontWeight: 900, margin: 0}}>Writing</h2>
      <a href="/writing/" class="view-all-link">查看全部 →</a>
    </div>
    <div class="grid-3" style={{display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: "24px", padding: "24px"}}>
      {featuredArticles.map((a, i) => (
        <div key={a.slug} class={"reveal reveal-delay-" + (i+1)}>
          <ProjectCard title={a.data.title} description={a.data.description} topics={a.data.tags} href={`/writing/${a.slug}/`} variant="uniform" />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  @media (max-width: 640px) {
    .hero-row {
      flex-direction: column !important;
    }
    .avatar-img {
      margin-top: 16px;
    }
  }
</style>
