---
import BaseLayout from "@/layouts/BaseLayout.astro";

const personaTags = ["PM", "郑州", "暴雪粉", "音乐狂", "收集癖", "强迫症"];

const deskDesktop = [
  ["CPU", "Intel i5-13600kf"],
  ["主板", "Asus TUF B760M-PLUS WIFI II"],
  ["显卡", "Asus TUF RTX 4070 SUPER O12G"],
  ["内存", "Corsair 16G×2 DDR5 6400"],
  ["固态", "Samsung 980PRO 1T + TiPlus7100 2TB"],
  ["散热", "DeepCool AK620"],
  ["电源", "Phanteks AMP GH850W"],
  ["机箱", "NZXT S340 Elite"],
  ["解码", "OCTAVART Champs-élysées + HD650"],
  ["音箱", "Bose C50"],
  ["键盘", "Filco 圣手二代 104 / Cherry G80-3000"],
  ["鼠标", "Logitech G903 + Master 3"],
  ["显示", "LG 34UC88-B + LG 27GR84Q-B"],
  ["耳机", "Sennheiser HD650 + Logitech G933"],
  ["路由", "Phicomm K3C"],
] as const;

const deskMobile = [
  ["笔记本", "MacBook Air M5 24G+1T"],
  ["显示", "Aoc U32N3C"],
  ["键盘", "NIZ T-35g C103 / IKBC Poker Pro 61"],
  ["鼠标", "Logitech Master 3 / MX Vertical"],
  ["耳机", "Bose QC35 II"],
  ["阅读", "Kindle Paperwhite 4"],
] as const;
---

<BaseLayout title="About" description="Kakarrot — AI 产品经理的经历与原则" canonical="/about/">
  <div class="container section page-shell" style="max-width:760px;margin-inline:auto">
    <header class="page-header">
      <p class="page-eyebrow">About</p>
      <h1 class="page-title">Kakarrot</h1>
      <p class="page-lead">AI 产品经理 · 坐标郑州</p>
      <div class="prose-header__tags" style="margin-top:20px">
        {personaTags.map((tag) => <span class="prose-tag">{tag}</span>)}
      </div>
    </header>

    <div class="reveal" style="font-size:17px;line-height:1.75;color:var(--color-body)">
      <p>
        大家好，我是 Kakarrot，一名拥有 <strong style="color:var(--color-ink)">10 年+经验</strong> 的产品经理。履历涵盖拓普丰联、宇通集团、南威集团等，熟悉 0→1 创业与 1→∞ 迭代。
      </p>
      <p>
        我擅长从第一性原理识别业务真正的问题，用 AI 原生方式重新设计产品与增长系统。当前也在整理全新的工作流——结合 AI 技术与直觉洞察，加速开发并激发协作。
      </p>

      <h2 style="font-size:13px;font-family:var(--font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--color-primary);margin:48px 0 16px">Timeline</h2>
      <p><strong style="color:var(--color-ink)">2020 前</strong> — 积累做事方法与阅读写作习惯。</p>
      <p><strong style="color:var(--color-ink)">2020 后</strong> — 系统梳理产品专业知识。</p>
      <p><strong style="color:var(--color-ink)">2022 后</strong> — 认识、拥抱、学习、研究 AI。</p>

      <h2 style="font-size:13px;font-family:var(--font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--color-primary);margin:48px 0 16px">Principles</h2>
      <ul style="padding-left:1.2rem;margin:0">
        <li>先理解问题，再设计方案。</li>
        <li>技术是手段，不是目的。</li>
        <li>最好的产品是那些用户感觉不到的产品。</li>
      </ul>

      <details style="margin-top:56px;border-top:1px solid var(--color-hairline);padding-top:24px" open>
        <summary style="cursor:pointer;font:500 12px/1 var(--font-mono);letter-spacing:0.08em;text-transform:uppercase;color:var(--color-muted)">
          Desk &amp; kit
        </summary>
        <div class="about-desk" style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-top:24px">
          <div>
            <p style="font:500 12px/1 var(--font-mono);letter-spacing:0.06em;text-transform:uppercase;color:var(--color-ink);margin:0 0 14px">桌面</p>
            <ul style="list-style:none;padding:0;margin:0;font-size:14px;line-height:1.75;color:var(--color-muted)">
              {
                deskDesktop.map(([k, v]) => (
                  <li>
                    <strong style="color:var(--color-ink);font-weight:600">{k}</strong>
                    {" "}
                    {v}
                  </li>
                ))
              }
            </ul>
          </div>
          <div>
            <p style="font:500 12px/1 var(--font-mono);letter-spacing:0.06em;text-transform:uppercase;color:var(--color-ink);margin:0 0 14px">移动</p>
            <ul style="list-style:none;padding:0;margin:0;font-size:14px;line-height:1.75;color:var(--color-muted)">
              {
                deskMobile.map(([k, v]) => (
                  <li>
                    <strong style="color:var(--color-ink);font-weight:600">{k}</strong>
                    {" "}
                    {v}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </details>
    </div>
  </div>
</BaseLayout>

<style>
  @media (max-width: 640px) {
    .about-desk {
      grid-template-columns: 1fr !important;
    }
  }
</style>
