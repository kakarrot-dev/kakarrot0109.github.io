---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title="项目" description="项目案例 — AI 产品实践" shell>
  <div style={{padding: "38px 30px", borderBottom: "2px solid var(--color-border-strong)"}}>
    <h1 style={{fontSize: "clamp(50px,7vw,100px)", letterSpacing: "-.07em", lineHeight: .9, fontWeight: 900, margin: "0 0 8px"}}>项目</h1>
    <p style={{font: "700 13px/1.5 ui-monospace,monospace", color: "var(--color-text-muted)", margin: 0}}>项目案例 &mdash; AI 产品实践</p>
  </div>
  <div style={{display: "grid", gridTemplateColumns: "1fr 1fr"}}>
    {projects.map((p, i) => (
      <div key={p.slug} style={{borderRight: i % 2 === 0 ? "2px solid var(--color-border-strong)" : "none", borderBottom: "2px solid var(--color-border-strong)"}}>
        <ProjectCard title={p.data.title} description={p.data.description} topics={p.data.topics} slug={p.slug} />
      </div>
    ))}
  </div>
</BaseLayout>
