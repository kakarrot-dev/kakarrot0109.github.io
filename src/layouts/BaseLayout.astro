---
import "@/styles/global.css";
import SeoHead from "@/components/SeoHead.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  shell?: boolean;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
}

const {
  title,
  description,
  canonical = Astro.url.pathname,
  shell,
  ogImage,
  ogType,
  publishedAt,
  updatedAt,
  tags,
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead
      {title}
      {description}
      canonical={canonical}
      {ogImage}
      {ogType}
      {publishedAt}
      {updatedAt}
      {tags}
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-T1TKDDHVNN"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-T1TKDDHVNN");
    </script>
  </head>
  <body>
    <noscript>
      <style>
        .reveal {
          opacity: 1 !important;
          transform: none !important;
        }
      </style>
    </noscript>
    <Nav />
    {
      shell ? (
        <main>
          <div class="shell shell--no-top-border">
            <slot />
          </div>
        </main>
      ) : (
        <main class="main-full">
          <slot />
        </main>
      )
    }
    <Footer />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );

      document.querySelectorAll(".reveal").forEach((el) =>
        observer.observe(el)
      );
    </script>
  </body>
</html>
