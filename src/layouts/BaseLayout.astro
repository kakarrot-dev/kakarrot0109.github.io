---
import "@/styles/global.css";
import SeoHead from "@/components/SeoHead.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  wide?: boolean;
}

const { title, description, canonical, wide } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead {title} {description} {canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <Nav />
    <main class:list={{ "max-w-5xl mx-auto px-6 py-12": !wide }}>
      {wide ? (
        <div style="max-width:1440px;margin:0 auto;border-left:2px solid var(--color-border-strong);border-right:2px solid var(--color-border-strong)">
          <slot />
        </div>
      ) : (
        <slot />
      )}
    </main>
    <Footer />
  </body>
</html>
