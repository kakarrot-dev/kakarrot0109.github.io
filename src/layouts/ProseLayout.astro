---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TableOfContents from "@/components/TableOfContents.astro";

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
  tagBase?: string;
  headings?: Heading[];
}

const {
  title,
  description,
  canonical,
  ogType = "article",
  publishedAt,
  updatedAt,
  tags = [],
  tagBase,
  headings = [],
} = Astro.props;

const timeLabel = publishedAt
  ? publishedAt.toLocaleDateString("en-CA").replace(/-/g, ".")
  : null;
const updatedLabel = updatedAt
  ? updatedAt.toLocaleDateString("en-CA").replace(/-/g, ".")
  : null;
const tocItems = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const hasToc = tocItems.length > 0;
---

<BaseLayout
  {title}
  {description}
  {canonical}
  {ogType}
  {publishedAt}
  {updatedAt}
  {tags}
>
  <div class:list={["prose-layout", !hasToc && "prose-layout--solo"]}>
    <article class="prose-layout__main prose">
      <header class="prose-header">
        <h1>{title}</h1>
        <p class="prose-header__desc">{description}</p>
        {
          timeLabel && (
            <p class="prose-header__time">
              {timeLabel}
              {updatedLabel ? ` · Updated ${updatedLabel}` : ""}
            </p>
          )
        }
        {
          tags.length > 0 && (
            <div class="prose-header__tags">
              {tags.map((tag) =>
                tagBase ? (
                  <a
                    class="prose-tag"
                    href={`${tagBase}${encodeURIComponent(tag)}/`}
                  >
                    {tag}
                  </a>
                ) : (
                  <span class="prose-tag">{tag}</span>
                )
              )}
            </div>
          )
        }
      </header>
      <slot />
    </article>
    {
      hasToc && (
        <aside class="prose-layout__toc">
          <TableOfContents headings={headings} />
        </aside>
      )
    }
  </div>
</BaseLayout>

<script>
  // 代码块：语言 + 图标复制（无顶栏背景）
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll<HTMLPreElement>(".prose .astro-code").forEach((pre) => {
      if (pre.parentElement?.classList.contains("code-block-wrap")) return;
      const lang = (pre.getAttribute("data-language") || "text").toUpperCase();
      if (lang === "MERMAID") return;

      const wrap = document.createElement("div");
      wrap.className = "code-block-wrap";

      const header = document.createElement("div");
      header.className = "code-block-header";

      const langSpan = document.createElement("span");
      langSpan.className = "code-lang";
      langSpan.textContent = lang;

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "copy-btn";
      copyBtn.setAttribute("aria-label", "复制代码");
      copyBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;

      copyBtn.addEventListener("click", async () => {
        const code = pre.querySelector("code")?.innerText || pre.innerText;
        try {
          await navigator.clipboard.writeText(code);
          copyBtn.classList.add("copied");
          copyBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>`;
          setTimeout(() => {
            copyBtn.classList.remove("copied");
            copyBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          }, 1600);
        } catch (err) {
          console.error("复制失败", err);
        }
      });

      header.append(langSpan, copyBtn);
      wrap.append(header);
      pre.before(wrap);
      wrap.appendChild(pre);
    });

    // Mermaid
    const mermaidBlocks = document.querySelectorAll<HTMLPreElement>(
      '.prose pre[data-language="mermaid"], .prose .astro-code[data-language="mermaid"]'
    );
    if (mermaidBlocks.length > 0) {
      void import("mermaid").then(async ({ default: mermaid }) => {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark";
        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? "dark" : "neutral",
          securityLevel: "loose",
        });
        let i = 0;
        for (const pre of mermaidBlocks) {
          const src = pre.querySelector("code")?.textContent || pre.textContent || "";
          const host = document.createElement("div");
          host.className = "mermaid";
          host.textContent = src.trim();
          pre.replaceWith(host);
          try {
            const id = `mermaid-${i++}`;
            const { svg } = await mermaid.render(id, src.trim());
            host.innerHTML = svg;
          } catch (e) {
            host.textContent = src.trim();
            console.error("Mermaid 渲染失败", e);
          }
        }
      });
    }

    // TOC 当前节
    const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>(".toc-list a")];
    const ids = tocLinks
      .map((a) => decodeURIComponent(a.getAttribute("href")?.slice(1) || ""))
      .filter(Boolean);
    const sections = ids
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => !!el);
    if (sections.length && "IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
          if (!visible?.target?.id) return;
          tocLinks.forEach((a) => {
            const on = a.getAttribute("href") === `#${visible.target.id}`;
            a.setAttribute("aria-current", on ? "true" : "false");
          });
        },
        { rootMargin: "-20% 0px -60% 0px", threshold: [0, 0.25, 0.5, 1] }
      );
      sections.forEach((s) => io.observe(s));
    }
  });
</script>
